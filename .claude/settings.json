{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash",
      "Glob",
      "Grep",
      "Agent",
      "Skill",
      "Monitor",
      "mcp__6dbed528-63fc-43dc-aeb1-9ac9433139a9__*",
      "mcp__6f95f74b-2c26-4dc1-ae0d-25420571532d__*",
      "mcp__92cfc3fb-28da-4ef9-9f33-83704617cf53__*",
      "mcp__c9ff3022-923b-456a-bbc1-326a15bb10fa__*",
      "mcp__github__*",
      "Skill(session-start-hook)",
      "Skill(update-config)",
      "Skill(keybindings-help)",
      "Skill(simplify)",
      "Skill(fewer-permission-prompts)",
      "Skill(loop)",
      "Skill(claude-api)",
      "Skill(init)",
      "Skill(review)",
      "Skill(security-review)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/user/awesome-claude-skills-zh-TW && git add -A && git status --short",
            "statusMessage": "📝 自動暫存文件變更",
            "async": false
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/user/awesome-claude-skills-zh-TW && if git diff-index --quiet HEAD --; then echo '✅ 無新變更'; else BRANCH=$(git rev-parse --abbrev-ref HEAD) && git push -u origin $BRANCH 2>&1 && echo '{\"systemMessage\": \"🚀 自動推送成功！分支已同步到遠程�倉庫\"}'; fi",
            "statusMessage": "🚀 自動推送到遠程倉庫",
            "async": false,
            "if": "Bash(git commit*)"
          }
        ]
      }
    ]
  }
}
